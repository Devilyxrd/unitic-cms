generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
}

enum EntryStatus {
  DRAFT
  PUBLISHED
}

enum FieldType {
  TEXT
  RICHTEXT
  NUMBER
  BOOLEAN
  DATE
  MEDIA
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  entries   Entry[]
}

model ContentType {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  createdAt DateTime       @default(now())

  fields    ContentField[]
  entries   Entry[]
}

model ContentField {
  id            String      @id @default(uuid())
  name          String
  type          FieldType
  required      Boolean     @default(false)

  contentType   ContentType @relation(fields: [contentTypeId], references: [id])
  contentTypeId String

  values        EntryValue[]
}

model Entry {
  id            String      @id @default(uuid())
  status        EntryStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  contentType   ContentType @relation(fields: [contentTypeId], references: [id])
  contentTypeId String

  author        User?       @relation(fields: [authorId], references: [id])
  authorId      String?

  values        EntryValue[]
}

model EntryValue {
  id       String       @id @default(uuid())
  value    Json

  entry    Entry        @relation(fields: [entryId], references: [id])
  entryId  String

  field    ContentField @relation(fields: [fieldId], references: [id])
  fieldId  String
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  size      Int
  url       String
  createdAt DateTime @default(now())
}
