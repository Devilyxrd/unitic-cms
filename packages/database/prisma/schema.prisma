generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
}

enum EntryStatus {
  DRAFT
  PUBLISHED
}

enum FieldType {
  TEXT
  RICHTEXT
  NUMBER
  BOOLEAN
  DATE
  MEDIA
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(EDITOR)

  isActive Boolean @default(true)
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   Entry[]
}

model ContentType {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields  ContentField[]
  entries Entry[]
}

model ContentField {
  id String @id @default(uuid())

  name String
  slug String

  type FieldType

  required Boolean @default(false)
  order    Int

  createdAt DateTime @default(now())

  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  contentTypeId String

  values EntryValue[]

  @@index([contentTypeId])
}

model Entry {
  id String @id @default(uuid())

  slug String? @unique

  status EntryStatus @default(DRAFT)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  contentTypeId String

  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?

  values EntryValue[]

  @@index([contentTypeId])
}

model EntryValue {
  id String @id @default(uuid())

  value Json?

  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId String

  field   ContentField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId String

  media   Media?  @relation(fields: [mediaId], references: [id])
  mediaId String?

  @@index([entryId])
}

model Media {
  id String @id @default(uuid())

  filename String
  mimeType String
  size     Int
  url      String

  createdAt DateTime @default(now())

  entryValues EntryValue[]
}
